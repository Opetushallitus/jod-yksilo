------------------------------------------------------------------------
-- Migration: yksilo-onr-updater
------------------------------------------------------------------------
BEGIN;
DO $$ BEGIN IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = 'onrupdater') THEN CREATE ROLE "onrupdater"; END IF; EXCEPTION WHEN duplicate_object THEN NULL; END $$;
ALTER ROLE onrupdater WITH LOGIN;
GRANT rds_iam TO onrupdater;
GRANT CONNECT,TEMPORARY ON DATABASE "yksilo" TO "onrupdater";
GRANT USAGE ON SCHEMA tunnistus TO onrupdater;
GRANT SELECT, UPDATE(oppijanumero, muokattu) ON tunnistus.henkilo TO onrupdater;
DROP POLICY IF EXISTS onrupdater_update_henkilo ON tunnistus.henkilo;
CREATE POLICY onrupdater_update_henkilo ON tunnistus.henkilo FOR ALL TO onrupdater USING (true);
COMMIT;

