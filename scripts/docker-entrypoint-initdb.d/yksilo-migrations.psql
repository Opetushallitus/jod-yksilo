  linkki_id          UUID;
  resolved_yksilo_id UUID;
BEGIN
  SELECT h.yksilo_id INTO resolved_yksilo_id
  FROM henkilo h
  WHERE h.henkilo_id = $1
     OR h.oppijanumero = $1;

  IF resolved_yksilo_id IS NULL THEN
