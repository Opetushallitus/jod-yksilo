CREATE OR REPLACE FUNCTION upsert_yksilo(
  p_henkilo_id VARCHAR(300),
  p_oppijanumero VARCHAR(300),
  p_etunimi TEXT,
  p_sukunimi TEXT
) RETURNS UUID AS $$
DECLARE
  id UUID;
BEGIN
  IF p_henkilo_id IS NULL AND p_oppijanumero IS NULL THEN
    RAISE EXCEPTION 'Either p_henkilo_id or p_oppijanumero must be non-null';
  END IF;

  MERGE INTO henkilo AS h
  USING (VALUES (p_henkilo_id, p_oppijanumero)) AS p(id, onr)
  ON h.henkilo_id = p.id OR h.oppijanumero = p.onr
  WHEN MATCHED AND h.henkilo_id IS NULL AND p.id IS NOT NULL THEN
    UPDATE SET henkilo_id = p.id,
               etunimi    = COALESCE(p_etunimi, h.etunimi),
               sukunimi   = COALESCE(p_sukunimi, h.sukunimi),
               muokattu   = CURRENT_TIMESTAMP
  WHEN MATCHED AND h.oppijanumero IS NULL AND p.onr IS NOT NULL THEN
    UPDATE SET oppijanumero = p.onr,
               etunimi      = COALESCE(p_etunimi, h.etunimi),
               sukunimi     = COALESCE(p_sukunimi, h.sukunimi),
               muokattu     = CURRENT_TIMESTAMP
  WHEN MATCHED AND (h.etunimi, h.sukunimi) IS DISTINCT FROM (p_etunimi, p_sukunimi) THEN
    UPDATE SET etunimi  = COALESCE(p_etunimi, h.etunimi),
               sukunimi = COALESCE(p_sukunimi, h.sukunimi),
               muokattu = CURRENT_TIMESTAMP
  WHEN NOT MATCHED THEN
    INSERT (yksilo_id, henkilo_id, oppijanumero, etunimi, sukunimi)
    VALUES (gen_random_uuid(), p.id, p.onr, p_etunimi, p_sukunimi);

  SELECT h.yksilo_id INTO STRICT id
  FROM henkilo h
  WHERE h.henkilo_id = p_henkilo_id
     OR h.oppijanumero = p_oppijanumero;

  RETURN id;
END
$$ LANGUAGE PLPGSQL SECURITY DEFINER
                    SET search_path = "tunnistus", pg_temp;
